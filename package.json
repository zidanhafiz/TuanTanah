{
  "name": "tuan-tanah",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tuan Tanah — multiplayer Indonesian-themed Monopoly web game",
  "scripts": {
    "dev": "pnpm --parallel --filter server --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "build": "pnpm --filter client build",
    "typecheck": "pnpm -r typecheck",
    "redis": "docker compose -f docker-compose.dev.yml up -d redis"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
