NODE_ENV=development
PORT=3000

# Postgres (optional — archives final game history on game-over; leave blank to disable).
# In the prod compose stack this is overridden to point at the postgres service.
# Dev (via docker-compose.dev.yml): postgres://tuan:tuan@localhost:5432/tuan_tanah
# Apply the schema with: pnpm --filter server migrate
DATABASE_URL=

# Redis — leave blank to use in-memory store (local dev without Docker).
# In the prod compose stack this is overridden to redis://redis:6379.
REDIS_URL=redis://localhost:6379

# Allowed browser origins (comma-separated). Defaults to the dev client.
# REQUIRED in production: set to your real origin(s); the server refuses to
# start in production if this is empty, a wildcard, or localhost.
# e.g. CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Game config
ROOM_TTL_HOURS=24

# Client (Vite) — URL the browser uses to reach the socket server.
# Leave blank in dev (Vite proxy) and in prod (same-origin via Caddy).
VITE_SERVER_URL=

# Public site origin used for social-share link previews (og:/twitter: tags),
# baked into index.html at build. Set to your prod URL, e.g. https://tuantanah.com.
# Leave blank for root-relative URLs (fine in dev / most crawlers).
VITE_PUBLIC_URL=

# --- Production only (used by docker-compose.yml / Caddy auto-TLS) ---
# Public domain Caddy issues a Let's Encrypt cert for. Use localhost to test
# the stack locally with an internal self-signed cert.
DOMAIN=yourdomain.com
# Contact email for Let's Encrypt expiry notices.
ACME_EMAIL=you@example.com
